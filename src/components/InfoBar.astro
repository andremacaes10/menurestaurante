---
import { config } from '../../client.config';
---

<div class="bg-white border-b border-gray-100 px-4 py-3">
  <div class="max-w-2xl mx-auto">
    <!-- Horários -->
    <div class="flex items-start gap-2 text-sm">
      <svg class="w-4 h-4 mt-0.5 text-brand-600 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div class="flex flex-col gap-0.5">
        {config.hours.map((h) => (
          <span class="text-gray-600">
            <span class="font-medium text-dark">{h.days}:</span> {h.time}
          </span>
        ))}
      </div>
    </div>

    <!-- Morada -->
    {config.contact.address && (
      <a
        href={config.contact.googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 mt-2 text-sm text-gray-600 hover:text-brand-700 transition-colors"
      >
        <svg class="w-4 h-4 text-brand-600 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span>{config.contact.address}</span>
        <svg class="w-3 h-3 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    )}

    <!-- Delivery badge -->
    {config.delivery.enabled && (
      <div class="flex items-center gap-2 mt-3 pt-3 border-t border-gray-100">
        <span class="flex items-center gap-1.5 text-xs font-semibold text-white bg-brand-600 px-2.5 py-1 rounded-full">
          🛵 Delivery disponível
        </span>
        <span class="text-xs text-gray-500">{config.delivery.estimatedTime}</span>
      </div>
    )}
  </div>
</div>
