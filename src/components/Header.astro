---
import { config } from '../../client.config';
---

<header class="relative overflow-hidden text-cream" style="background: #0c0a07;">

  <!-- Ambient warm glow — very subtle -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(196,133,38,0.18) 0%, transparent 65%);"
  ></div>

  <!-- Top ornament -->
  <div class="relative z-10 flex flex-col items-center pt-10 px-6">
    <div class="flex items-center gap-3 mb-6">
      <div class="h-px w-8 opacity-40" style="background: #c48526;"></div>
      <span class="text-xs tracking-[0.35em] uppercase font-sans font-medium" style="color: rgba(196,133,38,0.75);">
        Vila do Conde
      </span>
      <div class="h-px w-8 opacity-40" style="background: #c48526;"></div>
    </div>

    <!-- Restaurant name — Cormorant Garamond editorial -->
    <h1
      class="text-cream text-center leading-none tracking-tight"
      style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(3rem, 11vw, 5rem); font-weight: 600; letter-spacing: -0.02em; text-shadow: 0 2px 24px rgba(0,0,0,0.4);"
    >
      {config.name}
    </h1>

    <!-- Divider line -->
    <div class="flex items-center gap-3 mt-4 mb-3 w-full max-w-xs">
      <div class="flex-1 h-px opacity-25" style="background: #c48526;"></div>
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" style="opacity:0.5;">
        <circle cx="5" cy="5" r="2" fill="#c48526"/>
        <circle cx="5" cy="5" r="4.5" stroke="#c48526" stroke-width="0.7"/>
      </svg>
      <div class="flex-1 h-px opacity-25" style="background: #c48526;"></div>
    </div>

    <!-- Tagline -->
    <p
      class="text-xs font-sans tracking-[0.28em] uppercase mb-7"
      style="color: rgba(196,133,38,0.7);"
    >
      Food &amp; Drinks
    </p>

    <!-- Quick contacts — ghost buttons -->
    <div class="flex flex-wrap justify-center gap-2.5 pb-10">
      {config.contact.phone && (
        <a
          href={`tel:${config.contact.phone.replace(/\s/g, '')}`}
          class="flex items-center gap-2 text-xs font-medium px-4 py-2.5 rounded-full transition-all"
          style="border: 1px solid rgba(196,133,38,0.35); color: rgba(250,246,238,0.8); background: rgba(196,133,38,0.07);"
          aria-label="Ligar"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {config.contact.phone}
        </a>
      )}
      {config.social.instagram && (
        <a
          href={`https://www.instagram.com/${config.social.instagram}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-xs font-medium px-4 py-2.5 rounded-full transition-all"
          style="border: 1px solid rgba(196,133,38,0.35); color: rgba(250,246,238,0.8); background: rgba(196,133,38,0.07);"
          aria-label="Instagram"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 opacity-70" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          @{config.social.instagram}
        </a>
      )}
    </div>
  </div>

  <!-- Bottom fade to cream -->
  <div
    class="absolute bottom-0 left-0 right-0 h-10 pointer-events-none"
    style="background: linear-gradient(to bottom, transparent, #faf6ee);"
  ></div>
</header>
