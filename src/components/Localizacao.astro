---
import { config } from '../client.config';
---

<section id="localizacao" class="py-24 lg:py-36 bg-cream-dark">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <!-- Info -->
      <div class="reveal">
        <span class="section-label">Como Chegar</span>
        <h2 class="section-heading mb-6">
          Encontra-nos<br /><em class="text-gold not-italic">Em Caxinas</em>
        </h2>
        <div class="divider-gold mb-10"></div>

        <!-- Address -->
        <div class="space-y-6 mb-10">
          <div class="flex gap-4">
            <div class="w-10 h-10 bg-navy flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
            </div>
            <div>
              <div class="font-medium text-navy text-sm mb-1">Morada</div>
              <div class="text-gray-500 font-light text-sm leading-relaxed">
                {config.contact.address}<br />
                {config.contact.city}<br />
                {config.contact.postalCode}
              </div>
              <a
                href={config.contact.googleMapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gold hover:text-gold-dark text-xs font-medium tracking-wider uppercase mt-2 inline-flex items-center gap-1 transition-colors"
              >
                Ver no Google Maps
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                </svg>
              </a>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-10 h-10 bg-navy flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
              </svg>
            </div>
            <div>
              <div class="font-medium text-navy text-sm mb-1">Contacto</div>
              <a href={`tel:${config.contact.phone}`} class="text-gray-500 hover:text-navy font-light text-sm transition-colors block">{config.contact.phone}</a>
              <a href={`mailto:${config.contact.email}`} class="text-gray-500 hover:text-navy font-light text-sm transition-colors block">{config.contact.email}</a>
            </div>
          </div>
        </div>

        <!-- Hours table -->
        <div>
          <div class="font-medium text-navy text-sm mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Horário de Funcionamento
          </div>
          <div class="divide-y divide-cream-medium">
            {config.hours.map((h) => {
              const isToday = new Date().toLocaleDateString('pt-PT', { weekday: 'long' }).toLowerCase() === h.day.toLowerCase().split('-')[0];
              return (
                <div class={`flex justify-between items-center py-2.5 text-sm ${isToday ? 'font-medium text-navy' : 'text-gray-500 font-light'}`}>
                  <span class="flex items-center gap-2">
                    {isToday && <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>}
                    {h.day}
                  </span>
                  {h.closed
                    ? <span class="text-red-400/70 text-xs font-medium tracking-wide">Encerrado</span>
                    : <span>{h.open} – {h.close}</span>
                  }
                </div>
              );
            })}
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="reveal reveal-delay-2">
        <div class="aspect-[4/3] lg:aspect-auto lg:h-[540px] overflow-hidden bg-navy-light relative">
          <iframe
            src={config.contact.mapsEmbed}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localização do Lip Food & Drinks"
            class="absolute inset-0 w-full h-full"
          ></iframe>
        </div>

        <!-- Quick actions below map -->
        <div class="grid grid-cols-2 gap-px bg-cream-medium mt-px">
          <a
            href={`tel:${config.contact.phone}`}
            class="bg-cream flex items-center gap-3 p-5 hover:bg-navy group transition-colors duration-300"
          >
            <svg class="w-5 h-5 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            <div>
              <div class="font-medium text-navy group-hover:text-white text-xs tracking-wider uppercase transition-colors">Ligar</div>
              <div class="text-gray-400 group-hover:text-white/50 text-xs transition-colors">{config.contact.phone}</div>
            </div>
          </a>
          <a
            href={config.social.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-cream flex items-center gap-3 p-5 hover:bg-navy group transition-colors duration-300"
          >
            <svg class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <div>
              <div class="font-medium text-navy group-hover:text-white text-xs tracking-wider uppercase transition-colors">WhatsApp</div>
              <div class="text-gray-400 group-hover:text-white/50 text-xs transition-colors">Mensagem direta</div>
            </div>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
