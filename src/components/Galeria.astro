---
// Substitui as imagens por fotos reais do espaço e pratos
const photos = [
  { src: '/images/gallery-1.jpg', alt: 'Esplanada do Lip com vista para o Atlântico', span: 'col-span-2 row-span-2' },
  { src: '/images/gallery-2.jpg', alt: 'Interior do Lip Food & Drinks', span: '' },
  { src: '/images/gallery-3.jpg', alt: 'Mesa na esplanada com vista para o mar', span: '' },
  { src: '/images/gallery-4.jpg', alt: 'Espaço exterior do Lip nas Caxinas', span: '' },
  { src: '/images/gallery-5.jpg', alt: 'Ambiente do Lip Food & Drinks', span: '' },
  { src: '/images/gallery-6.jpg', alt: 'Vista para o oceano Atlântico', span: '' },
];

// Gradient placeholders com cores diferentes para quando não há fotos
const gradients = [
  'from-navy to-navy-light',
  'from-gold-dark to-gold',
  'from-navy-light to-navy',
  'from-gold to-gold-light',
  'from-navy-dark to-navy-light',
  'from-gold-dark to-navy',
];
---

<section class="py-24 lg:py-36 bg-cream">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">

    <div class="text-center mb-16 reveal">
      <span class="section-label">O Nosso Espaço</span>
      <h2 class="section-heading mb-4">Uma Vista<br /><em class="text-gold not-italic">Para Recordar</em></h2>
      <div class="divider-gold mx-auto"></div>
    </div>

    <!-- Masonry-style grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 lg:gap-3 auto-rows-[200px] lg:auto-rows-[220px] reveal">
      {photos.map((photo, i) => (
        <div class={`gallery-item relative overflow-hidden bg-navy-light group cursor-pointer ${photo.span}`}>
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <!-- Placeholder gradient -->
          <div class={`gallery-placeholder absolute inset-0 bg-gradient-to-br ${gradients[i]} flex items-end p-4`}>
            <span class="text-white/30 font-sans text-xs tracking-widest uppercase">{photo.alt}</span>
          </div>
          <!-- Hover overlay -->
          <div class="gallery-overlay absolute inset-0 bg-navy/40 opacity-0 transition-opacity duration-300 flex items-center justify-center">
            <svg class="w-10 h-10 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6"/>
            </svg>
          </div>
        </div>
      ))}
    </div>

    <!-- Instagram CTA -->
    <div class="text-center mt-12 reveal">
      <p class="text-gray-500 font-light mb-5">Vê mais momentos no nosso Instagram</p>
      <a
        href="https://www.instagram.com/lip_food.drinks/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost px-10 py-3.5 inline-flex items-center gap-3"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        @lip_food.drinks
      </a>
    </div>

  </div>
</section>

<script>
  // Hide placeholders when real images load
  document.querySelectorAll('.gallery-item img').forEach((img) => {
    const el = img as HTMLImageElement;
    const placeholder = el.nextElementSibling as HTMLElement;
    const checkLoad = () => {
      if (el.complete && el.naturalWidth > 0 && placeholder) {
        placeholder.style.display = 'none';
      }
    };
    checkLoad();
    el.addEventListener('load', checkLoad);
  });
</script>
