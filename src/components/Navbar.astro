---
import { config } from '../client.config';
---

<header id="nav-header" class="fixed top-0 left-0 right-0 z-50">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <nav class="flex items-center justify-between h-[72px] lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <!-- Bloco LI/P♦ replicando o logótipo da marca -->
        <div class="w-11 h-11 shrink-0 relative overflow-hidden" style="background: linear-gradient(135deg, #D08050 0%, #8C3E18 100%);">
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-0">
            <span class="font-serif text-white text-[11px] font-light tracking-[0.2em] leading-none">LI</span>
            <div class="w-5 h-px bg-white/40 my-0.5"></div>
            <span class="font-serif text-white text-[11px] font-light tracking-[0.1em] leading-none">P&#x25C6;</span>
          </div>
        </div>
        <div class="flex flex-col leading-none gap-0.5">
          <span class="logo-primary font-serif text-lg font-medium tracking-wide leading-none">Lip</span>
          <span class="logo-secondary font-sans text-[9px] tracking-[0.22em] uppercase leading-none">Food & Drinks</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden lg:flex items-center gap-7 xl:gap-9">
        {[
          { href: '/#sobre', label: 'O Espaço' },
          { href: '/#menu', label: 'Menu' },
          { href: '/#reservas', label: 'Reservas' },
          { href: '/encomendas', label: 'Encomendas' },
          { href: '/#localizacao', label: 'Localização' },
        ].map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link nav-text text-sm tracking-wide pb-0.5 border-b border-transparent hover:border-gold transition-colors duration-300"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-5">
        <a
          href={config.social.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="nav-text transition-colors duration-300 hover:!text-gold"
          aria-label="WhatsApp"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
        <a href="/#reservas" class="btn-primary py-2.5 px-6">Reservar Mesa</a>
      </div>

      <!-- Mobile toggle -->
      <button id="nav-toggle" class="lg:hidden p-2 nav-text" aria-label="Menu" aria-expanded="false">
        <svg id="nav-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7h16M4 12h16M4 17h16"/>
        </svg>
        <svg id="nav-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-nav" class="hidden lg:hidden bg-navy-dark/97 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto px-5 py-6 flex flex-col">
      {[
        { href: '/#sobre', label: 'O Espaço' },
        { href: '/#menu', label: 'Menu' },
        { href: '/#reservas', label: 'Reservas' },
        { href: '/encomendas', label: 'Encomendas Online' },
        { href: '/#localizacao', label: 'Localização' },
      ].map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link font-serif text-white/90 hover:text-gold text-xl font-light py-3.5 border-b border-white/10 transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
      <div class="flex gap-3 mt-6">
        <a href="/#reservas" class="btn-primary flex-1 py-3">Reservar Mesa</a>
        <a href={config.social.whatsapp} target="_blank" rel="noopener" class="btn-outline-white py-3 px-5">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('nav-header');
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('nav-icon-open');
  const iconClose = document.getElementById('nav-icon-close');

  // Scroll state
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      header?.setAttribute('data-scrolled', '');
    } else {
      header?.removeAttribute('data-scrolled');
    }
  }, { passive: true });

  // Mobile menu toggle
  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.contains('hidden') === false;
    if (isOpen) {
      mobileNav?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      mobileNav?.classList.remove('hidden');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });

  // Close on link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileNav?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
