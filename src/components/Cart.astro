---
import { config } from '../../client.config';
const { currency, takeaway } = config;
---

<!-- ===== FAB do carrinho ===== -->
<div id="cart-fab" class="fixed bottom-6 right-4 z-40 hidden">
  <button
    onclick="openCart()"
    class="flex items-center gap-2 bg-brand-600 hover:bg-brand-500 text-white font-semibold px-4 py-3 rounded-full shadow-2xl transition-all active:scale-95"
    aria-label="Ver pedido"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
    </svg>
    <span id="fab-count" class="text-sm">0 itens</span>
    <span class="text-brand-200 text-sm">·</span>
    <span id="fab-total" class="text-sm font-bold">€0.00</span>
  </button>
</div>

<!-- ===== Drawer ===== -->
<div id="cart-overlay" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeCart()"></div>

  <div
    id="cart-drawer"
    class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl max-h-[85vh] flex flex-col shadow-2xl"
    style="transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.32,0.72,0,1);"
  >
    <!-- Handle -->
    <div class="flex justify-center pt-3 pb-1 flex-shrink-0">
      <div class="w-10 h-1 bg-gray-300 rounded-full"></div>
    </div>

    <!-- Cabeçalho -->
    <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100 flex-shrink-0">
      <div>
        <h2 class="font-display text-lg font-bold text-dark">Pedido para Recolha</h2>
        <p class="text-xs text-gray-400">🥡 Pronto em {takeaway.estimatedTime}</p>
      </div>
      <button
        onclick="closeCart()"
        class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-100 text-gray-500 hover:bg-gray-200 transition-colors"
        aria-label="Fechar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Lista de itens -->
    <div class="flex-1 overflow-y-auto px-5 py-4">
      <div id="cart-empty" class="flex flex-col items-center justify-center py-12 text-center">
        <div class="text-5xl mb-3">🥡</div>
        <p class="font-semibold text-dark mb-1">O pedido está vazio</p>
        <p class="text-sm text-gray-400">Adiciona itens da ementa para encomendar</p>
      </div>
      <div id="cart-items-list" class="hidden flex-col gap-3"></div>
    </div>

    <!-- Rodapé -->
    <div id="cart-footer" class="hidden border-t border-gray-100 px-5 py-4 flex-shrink-0">
      <div class="flex justify-between font-bold text-dark text-base mb-4">
        <span>Total</span>
        <span id="cart-total-display">€0.00</span>
      </div>

      <button
        id="cart-send-btn"
        onclick="sendOrder()"
        class="w-full bg-green-600 hover:bg-green-500 text-white font-semibold py-3.5 rounded-2xl transition-colors flex items-center justify-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Confirmar Pedido via WhatsApp
      </button>
      <p class="text-xs text-center text-gray-400 mt-2">Levanta no balcão · {takeaway.estimatedTime}</p>
    </div>
  </div>
</div>

<script define:vars={{ whatsappNumber: takeaway.whatsapp, phoneNumber: config.contact.phone, currency, restaurantName: config.name }}>
  let cart = [];

  function addToCart(id, name, price) {
    const existing = cart.find(i => i.id === id);
    if (existing) {
      existing.qty += 1;
    } else {
      cart.push({ id, name, price, qty: 1 });
    }
    updateFab();
    renderCartItems();
    const btn = document.querySelector(`[data-cart-id="${id}"]`);
    if (btn) {
      btn.classList.add('ring-2', 'ring-brand-400', 'scale-110');
      setTimeout(() => btn.classList.remove('ring-2', 'ring-brand-400', 'scale-110'), 300);
    }
  }

  function updateQty(id, delta) {
    const item = cart.find(i => i.id === id);
    if (!item) return;
    item.qty += delta;
    if (item.qty <= 0) cart = cart.filter(i => i.id !== id);
    updateFab();
    renderCartItems();
  }

  function total() {
    return cart.reduce((s, i) => s + i.price * i.qty, 0);
  }

  function updateFab() {
    const fab = document.getElementById('cart-fab');
    const count = cart.reduce((s, i) => s + i.qty, 0);
    if (count === 0) { fab.classList.add('hidden'); return; }
    fab.classList.remove('hidden');
    document.getElementById('fab-count').textContent = count === 1 ? '1 item' : `${count} itens`;
    document.getElementById('fab-total').textContent = `${currency}${total().toFixed(2)}`;
  }

  function renderCartItems() {
    const list  = document.getElementById('cart-items-list');
    const empty = document.getElementById('cart-empty');
    const footer = document.getElementById('cart-footer');

    if (cart.length === 0) {
      list.classList.add('hidden');
      empty.classList.remove('hidden');
      footer.classList.add('hidden');
      return;
    }

    empty.classList.add('hidden');
    list.classList.remove('hidden');
    footer.classList.remove('hidden');

    list.innerHTML = '';
    cart.forEach(item => {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 bg-gray-50 rounded-2xl p-3';
      row.innerHTML = `
        <div class="flex-1 min-w-0">
          <p class="font-medium text-dark text-sm leading-snug truncate">${item.name}</p>
          <p class="text-xs text-gray-400 mt-0.5">${currency}${item.price.toFixed(2)} un.</p>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <button onclick="updateQty('${item.id}',-1)" class="w-7 h-7 rounded-full bg-white border border-gray-200 text-gray-600 font-bold flex items-center justify-center hover:bg-gray-100 transition-colors text-lg leading-none">−</button>
          <span class="w-5 text-center font-semibold text-dark text-sm">${item.qty}</span>
          <button onclick="updateQty('${item.id}',1)" class="w-7 h-7 rounded-full bg-brand-600 text-white font-bold flex items-center justify-center hover:bg-brand-500 transition-colors text-lg leading-none">+</button>
          <span class="w-14 text-right font-bold text-brand-700 text-sm">${currency}${(item.price * item.qty).toFixed(2)}</span>
        </div>
      `;
      list.appendChild(row);
    });

    document.getElementById('cart-total-display').textContent = `${currency}${total().toFixed(2)}`;
  }

  function openCart() {
    const overlay = document.getElementById('cart-overlay');
    const drawer  = document.getElementById('cart-drawer');
    overlay.classList.remove('hidden');
    requestAnimationFrame(() => { drawer.style.transform = 'translateY(0)'; });
    document.body.style.overflow = 'hidden';
    renderCartItems();
  }

  function closeCart() {
    const drawer = document.getElementById('cart-drawer');
    drawer.style.transform = 'translateY(100%)';
    setTimeout(() => {
      document.getElementById('cart-overlay').classList.add('hidden');
      document.body.style.overflow = '';
    }, 300);
  }

  function sendOrder() {
    const lines = cart.map(i => `• ${i.qty}x ${i.name} — ${currency}${(i.price * i.qty).toFixed(2)}`).join('\n');
    const msg = [
      `🥡 *Pedido para Recolha — ${restaurantName}*`,
      ``,
      lines,
      ``,
      `*Total: ${currency}${total().toFixed(2)}*`,
      ``,
      `📞 O meu contacto:`,
      `⏰ Hora de recolha pretendida:`,
    ].join('\n');

    const encoded = encodeURIComponent(msg);
    if (whatsappNumber) {
      window.open(`https://wa.me/${whatsappNumber}?text=${encoded}`, '_blank');
    } else {
      if (navigator.clipboard) navigator.clipboard.writeText(msg);
      window.location.href = `tel:${phoneNumber.replace(/\s/g,'')}`;
    }
  }

  window.addToCart  = addToCart;
  window.updateQty  = updateQty;
  window.openCart   = openCart;
  window.closeCart  = closeCart;
</script>
