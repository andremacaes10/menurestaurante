---
import { config } from '../../client.config';

interface MenuItem {
  id: string;
  name: string;
  description: string;
  price: number;
  tags: string[];
  available: boolean;
  featured: boolean;
  image: string;
}

interface MenuSectionProps {
  id: string;
  category: string;
  group: string;
  emoji: string;
  items: MenuItem[];
  initiallyHidden?: boolean;
}

const { id, category, group, emoji, items, initiallyHidden = false } = Astro.props as MenuSectionProps;
const currency = config.currency;
---

<section
  class="menu-section px-4 max-w-2xl mx-auto mb-10"
  data-section={id}
  data-group={group}
  id={`section-${id}`}
  style={initiallyHidden ? 'display:none' : ''}
>
  <!-- Cabeçalho da secção — estilo editorial -->
  <div class="flex items-end gap-3 mb-5 pt-4">
    <h2 class="font-display text-2xl font-bold text-ink leading-none">{category}</h2>
    <span class="text-lg leading-none mb-0.5 opacity-70">{emoji}</span>
    <div class="flex-1 h-px self-center" style="background: linear-gradient(to right, rgba(196,133,38,0.35), transparent);"></div>
  </div>

  <!-- Itens -->
  <div class="flex flex-col gap-3">
    {items.map((item) => (
      <div
        class={`menu-item-card menu-card bg-white rounded-2xl overflow-hidden ${!item.available ? 'opacity-50' : ''}`}
        style="box-shadow: 0 1px 4px rgba(0,0,0,0.07);"
        data-name={item.name.toLowerCase()}
        data-desc={item.description.toLowerCase()}
      >
        <!-- Foto (se existir) -->
        {item.image && (
          <div class="relative overflow-hidden">
            <img
              src={item.image}
              alt={item.name}
              class="w-full object-cover"
              style="height: 11rem;"
              loading="lazy"
              width="600"
              height="176"
            />
            {!item.available && (
              <div class="absolute inset-0 bg-black/50 flex items-center justify-center">
                <span class="text-white font-semibold text-sm bg-black/60 px-3 py-1 rounded-full">Esgotado</span>
              </div>
            )}
            {item.featured && (
              <span
                class="absolute top-2.5 left-2.5 text-xs font-semibold tracking-wide uppercase px-2.5 py-1 rounded-full"
                style="background: rgba(12,10,7,0.75); color: rgba(196,133,38,1); backdrop-filter: blur(4px);"
              >
                ★ Destaque
              </span>
            )}
          </div>
        )}

        <!-- Conteúdo -->
        <div class="flex items-start justify-between gap-3 px-4 py-3.5">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <h3 class="font-display font-semibold text-ink leading-snug" style="font-size: 0.9375rem;">
                {item.name}
              </h3>
              {item.featured && !item.image && (
                <span
                  class="inline-flex items-center text-xs font-medium px-1.5 py-0.5 rounded"
                  style="background: rgba(196,133,38,0.1); color: #a86c20;"
                >
                  ★ Destaque
                </span>
              )}
              {!item.available && !item.image && (
                <span class="text-xs text-stone italic">Esgotado</span>
              )}
            </div>
            {item.description && (
              <p class="text-stone text-xs mt-1 leading-relaxed">{item.description}</p>
            )}
            {item.tags.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-2">
                {item.tags.map((tag) => {
                  const tagClass =
                    tag === 'vegan'       ? 'tag-vegan' :
                    tag === 'vegetariano' ? 'tag-vegetariano' :
                    tag === 'sem glúten'  ? 'tag-sem-gluten' :
                    tag === 'picante'     ? 'tag-picante' : '';
                  return <span class={`tag-badge ${tagClass}`}>{config.tagLabels[tag] ?? tag}</span>;
                })}
              </div>
            )}
          </div>

          <!-- Preço + botão -->
          <div class="flex-shrink-0 self-center flex flex-col items-end gap-2">
            <span class="price-badge">{currency}{item.price.toFixed(2)}</span>
            {item.available && (
              <button
                class="w-8 h-8 rounded-full text-white font-bold text-lg flex items-center justify-center transition-all active:scale-95"
                style="background: #a86c20; box-shadow: 0 2px 8px rgba(168,108,32,0.35);"
                data-cart-id={item.id}
                data-cart-name={item.name}
                data-cart-price={item.price.toString()}
                onclick="addToCart(this.dataset.cartId, this.dataset.cartName, parseFloat(this.dataset.cartPrice))"
                aria-label={`Adicionar ${item.name}`}
              >+</button>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
