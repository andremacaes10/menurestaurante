---
import { config } from '../../client.config';

interface MenuItem {
  id: string;
  name: string;
  description: string;
  price: number;
  tags: string[];
  available: boolean;
  featured: boolean;
  image: string;
}

interface MenuSectionProps {
  id: string;
  category: string;
  group: string;
  emoji: string;
  items: MenuItem[];
  initiallyHidden?: boolean;
}

const { id, category, group, emoji, items, initiallyHidden = false } = Astro.props as MenuSectionProps;
const currency = config.currency;
---

<section
  class="menu-section px-4 max-w-2xl mx-auto mb-8"
  data-section={id}
  data-group={group}
  id={`section-${id}`}
  style={initiallyHidden ? 'display:none' : ''}
>
  <!-- Título da secção -->
  <div class="flex items-center gap-2 mb-4 pt-2">
    <span class="text-2xl">{emoji}</span>
    <h2 class="font-display text-xl font-bold text-dark">{category}</h2>
    <div class="flex-1 h-px bg-gray-200"></div>
  </div>

  <!-- Grid de pratos -->
  <div class="flex flex-col gap-3">
    {items.map((item) => (
      <div
        class={`menu-item-card menu-card bg-white rounded-2xl p-4 border border-gray-100 ${!item.available ? 'opacity-50' : ''}`}
        data-name={item.name.toLowerCase()}
        data-desc={item.description.toLowerCase()}
      >
        <!-- Foto do prato (se existir) — ocupa largura total no topo -->
        {item.image && (
          <div class="relative -mx-4 -mt-4 mb-3 rounded-t-2xl overflow-hidden">
            <img
              src={item.image}
              alt={item.name}
              class="w-full h-44 object-cover"
              loading="lazy"
              width="600"
              height="176"
            />
            {!item.available && (
              <div class="absolute inset-0 bg-black/50 flex items-center justify-center">
                <span class="text-white font-semibold text-sm bg-black/60 px-3 py-1 rounded-full">Esgotado</span>
              </div>
            )}
          </div>
        )}

        <!-- Conteúdo -->
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-1.5 flex-wrap">
              <h3 class={`font-semibold text-dark leading-snug ${item.image ? 'text-base' : 'text-sm'}`}>
                {item.name}
              </h3>
              {item.featured && (
                <span class="inline-flex items-center gap-0.5 text-xs font-medium text-brand-700 bg-brand-50 border border-brand-200 px-1.5 py-0.5 rounded-full">
                  ⭐ Destaque
                </span>
              )}
              {!item.available && !item.image && (
                <span class="text-xs text-gray-400 italic">Esgotado</span>
              )}
            </div>
            {item.description && (
              <p class="text-gray-500 text-xs mt-1 leading-relaxed">
                {item.description}
              </p>
            )}
            <!-- Tags / alergénios -->
            {item.tags.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-2">
                {item.tags.map((tag) => {
                  const tagClass =
                    tag === 'vegan' ? 'tag-vegan' :
                    tag === 'vegetariano' ? 'tag-vegetariano' :
                    tag === 'sem glúten' ? 'tag-sem-gluten' :
                    tag === 'picante' ? 'tag-picante' : '';
                  return (
                    <span class={`tag-badge ${tagClass}`}>
                      {config.tagLabels[tag] ?? tag}
                    </span>
                  );
                })}
              </div>
            )}
          </div>

          <!-- Preço -->
          <div class="flex-shrink-0 text-right">
            <span class={`font-bold text-brand-700 ${item.image ? 'text-lg' : 'text-base'}`}>
              {currency}{item.price.toFixed(2)}
            </span>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
