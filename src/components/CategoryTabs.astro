---
import { config } from '../../client.config';

const groupSections = config.menuGroups.map((g) => ({
  id: g.id,
  sections: config.menu
    .filter((s) => s.group === g.id)
    .map((s) => ({ id: s.id, category: s.category, emoji: s.emoji })),
}));
---

<!-- ===== NÍVEL 1: grupos principais (fundo escuro) ===== -->
<div class="px-2 pt-1 pb-0" style="background: #0c0a07;">
  <div class="flex max-w-2xl mx-auto">
    {config.menuGroups.map((group, i) => (
      <button
        class={`group-tab flex-1 flex flex-col items-center gap-1 py-3 border-b-2 text-xs font-medium tracking-wide transition-all duration-200 cursor-pointer ${
          i === 0
            ? 'border-brand-500 text-brand-300'
            : 'border-transparent text-stone hover:text-gray-300'
        }`}
        data-group={group.id}
        onclick={`selectGroup('${group.id}')`}
      >
        <span class="text-lg leading-none">{group.emoji}</span>
        <span class="leading-tight text-center uppercase tracking-wider" style="font-size: 0.65rem;">{group.label}</span>
      </button>
    ))}
  </div>
</div>

<!-- ===== NÍVEL 2: sub-categorias (sticky, fundo cream) ===== -->
<div id="category-bar" class="sticky top-0 z-30 bg-cream sticky-bar-shadow border-b border-gray-100">
  <div id="sub-tabs" class="flex overflow-x-auto scrollbar-none max-w-2xl mx-auto px-4">
    <!-- preenchido pelo JS -->
  </div>
</div>

<!-- Barra de pesquisa -->
<div class="px-4 py-3 max-w-2xl mx-auto">
  <div class="relative">
    <svg
      class="absolute left-3.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-stone pointer-events-none"
      xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
      stroke="currentColor" stroke-width="2.5"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <input
      type="search"
      id="search-input"
      placeholder="Pesquisar na ementa…"
      class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 bg-white text-sm text-ink placeholder-stone
             focus:outline-none focus:ring-2 focus:ring-brand-400/40 focus:border-brand-400 transition-all"
      oninput="searchMenu(this.value)"
    />
  </div>
</div>

<script define:vars={{ groupSections }}>
  let activeGroup   = groupSections[0]?.id ?? '';
  let activeSection = 'all';

  function renderSubTabs(groupId) {
    const bar = document.getElementById('sub-tabs');
    if (!bar) return;
    const group = groupSections.find((g) => g.id === groupId);
    if (!group) return;

    bar.innerHTML = '';

    const allBtn = document.createElement('button');
    allBtn.className = 'category-tab category-tab-active';
    allBtn.dataset.category = 'all';
    allBtn.textContent = 'Tudo';
    allBtn.onclick = () => filterSection('all');
    bar.appendChild(allBtn);

    group.sections.forEach((s) => {
      const btn = document.createElement('button');
      btn.className = 'category-tab category-tab-inactive';
      btn.dataset.category = s.id;
      btn.textContent = s.category;
      btn.onclick = () => filterSection(s.id);
      bar.appendChild(btn);
    });

    activeSection = 'all';
  }

  function selectGroup(groupId) {
    activeGroup = groupId;

    document.querySelectorAll('.group-tab').forEach((tab) => {
      const el = tab;
      if (el.dataset.group === groupId) {
        el.classList.remove('border-transparent', 'text-stone', 'hover:text-gray-300');
        el.classList.add('border-brand-500', 'text-brand-300');
      } else {
        el.classList.remove('border-brand-500', 'text-brand-300');
        el.classList.add('border-transparent', 'text-stone', 'hover:text-gray-300');
      }
    });

    document.querySelectorAll('.menu-section').forEach((s) => {
      const el = s;
      if (el.dataset.group === groupId) {
        el.style.display = '';
        el.classList.remove('section-enter');
        void el.offsetWidth;
        el.classList.add('section-enter');
      } else {
        el.style.display = 'none';
      }
    });

    const searchInput = document.getElementById('search-input');
    if (searchInput) searchInput.value = '';
    document.querySelectorAll('.menu-item-card').forEach((c) => { c.style.display = ''; });

    renderSubTabs(groupId);
  }

  function filterSection(sectionId) {
    activeSection = sectionId;

    document.querySelectorAll('#sub-tabs .category-tab').forEach((tab) => {
      const el = tab;
      if (el.dataset.category === sectionId) {
        el.classList.remove('category-tab-inactive');
        el.classList.add('category-tab-active');
      } else {
        el.classList.remove('category-tab-active');
        el.classList.add('category-tab-inactive');
      }
    });

    document.querySelectorAll('.menu-section').forEach((s) => {
      const el = s;
      if (el.dataset.group !== activeGroup) { el.style.display = 'none'; return; }
      const shouldShow = sectionId === 'all' || el.dataset.section === sectionId;
      if (shouldShow) {
        el.style.display = '';
        el.classList.remove('section-enter');
        void el.offsetWidth;
        el.classList.add('section-enter');
      } else {
        el.style.display = 'none';
      }
    });

    const searchInput = document.getElementById('search-input');
    if (searchInput) searchInput.value = '';
    document.querySelectorAll('.menu-item-card').forEach((c) => { c.style.display = ''; });
  }

  function searchMenu(query) {
    const q = query.toLowerCase().trim();
    if (!q) {
      document.querySelectorAll('.menu-section').forEach((s) => {
        const el = s;
        if (el.dataset.group !== activeGroup) { el.style.display = 'none'; return; }
        el.style.display = activeSection === 'all' || el.dataset.section === activeSection ? '' : 'none';
      });
      document.querySelectorAll('.menu-item-card').forEach((c) => { c.style.display = ''; });
      return;
    }

    document.querySelectorAll('.menu-section').forEach((s) => { s.style.display = ''; });
    document.querySelectorAll('.menu-item-card').forEach((card) => {
      const el = card;
      const name = el.dataset.name?.toLowerCase() ?? '';
      const desc = el.dataset.desc?.toLowerCase() ?? '';
      el.style.display = name.includes(q) || desc.includes(q) ? '' : 'none';
    });
    document.querySelectorAll('.menu-section').forEach((s) => {
      const visible = s.querySelectorAll('.menu-item-card:not([style*="none"])').length > 0;
      s.style.display = visible ? '' : 'none';
    });
  }

  window.selectGroup   = selectGroup;
  window.filterSection = filterSection;
  window.searchMenu    = searchMenu;

  renderSubTabs(activeGroup);
</script>

<style>
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-none::-webkit-scrollbar { display: none; }
</style>
