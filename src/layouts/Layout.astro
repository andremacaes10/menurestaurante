---
import '../styles/global.css';
import { config } from '../../client.config';

interface Props {
  title?: string;
  description?: string;
}

const { title = config.seo.title, description = config.seo.description } = Astro.props;
const canonicalUrl = Astro.url.href;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "name": config.name,
  "description": config.description,
  "url": Astro.site?.toString() ?? canonicalUrl,
  "telephone": config.contact.phone,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": config.contact.address,
    "addressLocality": config.contact.city,
    "addressCountry": "PT"
  },
  "openingHoursSpecification": config.hours.map(h => ({
    "@type": "OpeningHoursSpecification",
    "description": `${h.days}: ${h.time}`
  })),
  "hasMenu": canonicalUrl,
  "servesCuisine": "Portuguese",
  "priceRange": "€€",
};
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#d4821e" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={config.images.hero} />
    <meta property="og:locale" content="pt_PT" />

    <title>{title}</title>

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
